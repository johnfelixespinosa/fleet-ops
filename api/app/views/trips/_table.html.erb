<% if trips.any? %>
<div class="glass-panel rounded-2xl shadow-sm overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-slate-100">
    <h2 class="text-lg font-bold text-slate-900"><%= title %></h2>
  </div>
  <table class="min-w-full">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Trip</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Route</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Date</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Distance</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Cargo</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Energy</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Status</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% trips.each do |trip| %>
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="px-5 py-3 text-sm font-bold text-slate-900"><%= trip.trip_number %></td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= trip.origin %> &rarr; <%= trip.destination %></td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= trip.departure_at.strftime("%a %b %-d, %H:%M") %></td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_with_delimiter(trip.distance_miles) %> mi</td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_with_delimiter(trip.cargo_weight_lbs) %> lbs</td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= trip.energy_consumed_kwh ? "#{trip.energy_consumed_kwh} kWh" : "—" %></td>
          <td class="px-5 py-3 text-sm"><%= trip_status_badge(trip.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
