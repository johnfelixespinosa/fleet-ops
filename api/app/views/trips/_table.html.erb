<% if trips.any? %>
<div class="bg-white rounded-lg shadow overflow-hidden mb-6">
  <div class="px-5 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900"><%= title %></h2>
  </div>
  <table class="min-w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trip</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Route</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Distance</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Cargo</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Energy</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% trips.each do |trip| %>
        <tr class="even:bg-gray-50">
          <td class="px-5 py-3 text-sm font-medium text-gray-900"><%= trip.trip_number %></td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= trip.origin %> &rarr; <%= trip.destination %></td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= trip.departure_at.strftime("%a %b %-d, %H:%M") %></td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= number_with_delimiter(trip.distance_miles) %> mi</td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= number_with_delimiter(trip.cargo_weight_lbs) %> lbs</td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= trip.energy_consumed_kwh ? "#{trip.energy_consumed_kwh} kWh" : "—" %></td>
          <td class="px-5 py-3 text-sm"><%= trip_status_badge(trip.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
