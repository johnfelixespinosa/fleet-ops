<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "FleetOps" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-slate-800 text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center space-x-8">
            <%= link_to "FleetOps", root_path, class: "text-lg font-bold tracking-tight" %>
            <div class="flex space-x-4 text-sm">
              <%= link_to "Dashboard", root_path, class: "text-slate-300 hover:text-white" %>
              <%= link_to "Vehicles", vehicles_path, class: "text-slate-300 hover:text-white" %>
              <%= link_to "Service Centers", service_centers_path, class: "text-slate-300 hover:text-white" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
