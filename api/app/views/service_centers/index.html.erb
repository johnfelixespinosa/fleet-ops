<% content_for(:title) { "FleetOps — Service Centers" } %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Service Centers</h1>
  <p class="text-sm text-gray-500 mt-1"><%= @service_centers.count %> centers along California routes</p>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">City</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Certifications</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Capabilities</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Contact</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @service_centers.each do |center| %>
        <tr class="even:bg-gray-50">
          <td class="px-5 py-3 text-sm font-medium text-gray-900"><%= center.name %></td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= center.city %></td>
          <td class="px-5 py-3 text-sm">
            <% if center.is_partner %>
              <span class="inline-block px-2 py-1 rounded text-xs font-medium bg-green-100 text-green-800 mr-1">Partner</span>
            <% end %>
            <% if center.ev_certified %>
              <span class="inline-block px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800">EV Certified</span>
            <% end %>
          </td>
          <td class="px-5 py-3 text-sm text-gray-600">
            <%= center.capabilities&.map { |c| c.titleize }&.join(", ") %>
          </td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= center.contact_email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
