<% content_for(:title) { "FleetOps — Service Centers" } %>
<% content_for(:page_heading) { "Service Centers" } %>
<% content_for(:page_subheading) { "#{@service_centers.count} centers along California routes" } %>

<div class="glass-panel rounded-2xl shadow-sm overflow-hidden">
  <table class="min-w-full">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Name</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">City</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Certifications</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Capabilities</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Contact</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @service_centers.each do |center| %>
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="px-5 py-3 text-sm font-medium text-slate-900"><%= center.name %></td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= center.city %></td>
          <td class="px-5 py-3 text-sm">
            <% if center.is_partner %>
              <span class="inline-block px-2 py-1 rounded-md text-xs font-medium bg-teal-50 text-teal-700 border border-teal-100 mr-1">Partner</span>
            <% end %>
            <% if center.ev_certified %>
              <span class="inline-block px-2 py-1 rounded-md text-xs font-medium bg-slate-100 text-slate-700 border border-slate-200">EV Certified</span>
            <% end %>
          </td>
          <td class="px-5 py-3 text-sm text-slate-600">
            <%= center.capabilities&.map { |c| c.titleize }&.join(", ") %>
          </td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= center.contact_email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
