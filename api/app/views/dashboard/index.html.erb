<% content_for(:title) { "FleetOps — Dashboard" } %>
<% content_for(:page_heading) { "System Overview" } %>
<% content_for(:page_subheading) do %>
  <span class="flex items-center gap-1.5">
    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    <%= Time.current.strftime("%b %-d, %Y") %>
    <span class="text-slate-300">|</span>
    <%= Time.current.strftime("%I:%M %p %Z") %>
  </span>
<% end %>

<div class="space-y-6">
  <!-- Summary Stats -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Total Fleet -->
    <div class="glass-panel rounded-2xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Total Fleet</p>
          <h3 class="text-3xl font-bold text-slate-900 mt-1"><%= @vehicle_count %></h3>
        </div>
        <div class="w-10 h-10 rounded-lg bg-slate-50 flex items-center justify-center border border-slate-100">
          <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
          </svg>
        </div>
      </div>
      <div class="flex items-center text-sm">
        <span class="text-teal-700 font-semibold bg-teal-50 px-2 py-0.5 rounded-md border border-teal-100">
          <%= @active_count %> active
        </span>
      </div>
    </div>

    <!-- Active on Route -->
    <div class="glass-panel rounded-2xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Active on Route</p>
          <h3 class="text-3xl font-bold text-teal-600 mt-1"><%= @active_count %></h3>
        </div>
        <div class="w-10 h-10 rounded-lg bg-teal-50 flex items-center justify-center border border-teal-100">
          <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>
      </div>
      <% utilization = @vehicle_count > 0 ? (@active_count.to_f / @vehicle_count * 100).round : 0 %>
      <div class="flex items-center text-sm">
        <span class="text-slate-500"><%= utilization %>% utilization rate</span>
      </div>
      <div class="w-full h-1.5 bg-slate-100 rounded-full mt-3 overflow-hidden">
        <div class="h-full bg-teal-500 rounded-full" style="width: <%= utilization %>%"></div>
      </div>
    </div>

    <!-- Low Battery -->
    <div class="glass-panel rounded-2xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Low Battery</p>
          <h3 class="text-3xl font-bold text-slate-900 mt-1"><%= @low_battery.count %></h3>
        </div>
        <div class="w-10 h-10 rounded-lg bg-slate-900 flex items-center justify-center border border-slate-800">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
      </div>
      <div class="flex items-center text-sm">
        <span class="text-slate-600 font-medium">Below 95% health</span>
      </div>
    </div>

    <!-- Needs Attention -->
    <div class="glass-panel rounded-2xl p-6 shadow-sm">
      <div class="flex justify-between items-start mb-4">
        <div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Needs Attention</p>
          <h3 class="text-3xl font-bold text-slate-900 mt-1"><%= @needing_attention.count %></h3>
        </div>
        <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center border border-slate-200">
          <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
      </div>
      <div class="flex items-center text-sm">
        <span class="text-slate-500">Within 5,000 mi of service</span>
      </div>
    </div>
  </div>

  <!-- Two-Column: Maintenance Alerts + EV Fleet Health -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Maintenance Alerts (2/3) -->
    <div class="lg:col-span-2 glass-panel rounded-2xl p-6 flex flex-col shadow-sm max-h-[420px]">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-slate-900"></div>
          Maintenance Alerts
        </h2>
        <%= link_to "View All", vehicles_path, class: "text-xs font-bold text-slate-500 hover:text-slate-900 transition-colors bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200" %>
      </div>

      <% if @needing_attention.any? %>
        <div class="flex-1 overflow-y-auto pr-2 space-y-3">
          <% @needing_attention.each do |vehicle| %>
            <div class="bg-slate-50 border border-slate-200 hover:border-slate-300 transition-all rounded-xl p-4 flex items-center justify-between group">
              <div class="flex items-center gap-3 flex-shrink-0">
                <%= vehicle_icon(vehicle.make, size: 36) %>
                <div>
                  <p class="font-bold text-slate-900 text-sm"><%= vehicle.unit_number %></p>
                  <p class="text-xs text-slate-500"><%= vehicle.make %> <%= vehicle.model %></p>
                </div>
              </div>
              <div class="flex-1 px-4 hidden sm:block">
                <p class="text-sm text-slate-600">
                  <%= number_with_delimiter(vehicle.miles_to_maintenance) %> mi to <%= vehicle.next_maintenance_type.titleize %>
                </p>
              </div>
              <div class="flex items-center gap-3">
                <% severity = vehicle.miles_to_maintenance < 2000 ? "Critical" : "Warning" %>
                <span class="px-2.5 py-1 rounded-md text-xs font-bold <%= severity == 'Critical' ? 'bg-slate-200 text-slate-900' : 'bg-slate-100 text-slate-600' %>">
                  <%= severity %>
                </span>
                <%= link_to vehicle_path(vehicle), class: "w-8 h-8 rounded-lg bg-white border border-slate-200 flex items-center justify-center hover:bg-slate-100 text-slate-600 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex-1 flex items-center justify-center text-sm text-slate-400">
          All vehicles are up to date
        </div>
      <% end %>
    </div>

    <!-- EV Fleet Health (1/3) -->
    <div class="glass-panel rounded-2xl p-6 flex flex-col shadow-sm max-h-[420px]">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
          <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
          </svg>
          EV Fleet Health
        </h2>
        <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-1 rounded-md border border-slate-200">
          <%= @low_battery.count %> Issue<%= @low_battery.count == 1 ? "" : "s" %>
        </span>
      </div>

      <!-- Circular Progress -->
      <div class="flex justify-center mb-4">
        <div class="relative w-28 h-28 flex items-center justify-center">
          <% health = @avg_battery_health %>
          <% offset = (283 * (100 - health) / 100.0).round %>
          <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="45" fill="none" stroke="#F1F5F9" stroke-width="8"/>
            <circle cx="50" cy="50" r="45" fill="none" stroke="#0D9488" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="<%= offset %>" stroke-linecap="round"/>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-2xl font-bold text-slate-900"><%= health %>%</span>
            <span class="text-[10px] text-slate-400 uppercase tracking-widest font-bold">Avg Health</span>
          </div>
        </div>
      </div>

      <!-- Per-Vehicle Battery Bars -->
      <% if @low_battery.any? %>
        <div class="flex-1 overflow-y-auto space-y-3 pr-1">
          <% @low_battery.each do |vehicle| %>
            <% critical_battery = vehicle.battery_health_percent < 80 %>
            <div class="space-y-1">
              <div class="flex justify-between text-sm">
                <span class="font-bold text-slate-900 flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full <%= critical_battery ? 'bg-slate-900' : 'bg-slate-400' %>"></div>
                  <%= vehicle.unit_number %>
                </span>
                <span class="font-bold <%= critical_battery ? 'text-slate-900' : 'text-slate-600' %>"><%= vehicle.battery_health_percent %>%</span>
              </div>
              <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full <%= critical_battery ? 'bg-slate-900' : 'bg-slate-400' %>" style="width: <%= vehicle.battery_health_percent %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex-1 flex items-center justify-center text-sm text-slate-400">
          All batteries healthy
        </div>
      <% end %>
    </div>
  </div>

  <!-- Upcoming Trips -->
  <% if @upcoming_trips.any? %>
    <div class="glass-panel rounded-2xl p-6 shadow-sm overflow-hidden">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
          <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          Upcoming Trips
        </h2>
        <span class="text-xs text-slate-500">Next 7 days</span>
      </div>

      <div class="overflow-x-auto rounded-xl border border-slate-100">
        <table class="min-w-full">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Trip</th>
              <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Vehicle</th>
              <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Route</th>
              <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Date</th>
              <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Distance</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @upcoming_trips.each do |trip| %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-5 py-3 text-sm font-bold text-slate-900"><%= trip.trip_number %></td>
                <td class="px-5 py-3 text-sm">
                  <%= link_to trip.vehicle.unit_number, vehicle_path(trip.vehicle), class: "text-teal-600 hover:text-teal-700 font-medium" %>
                </td>
                <td class="px-5 py-3 text-sm text-slate-600"><%= trip.origin %> &rarr; <%= trip.destination %></td>
                <td class="px-5 py-3 text-sm text-slate-600"><%= trip.departure_at.strftime("%a %b %-d, %H:%M") %></td>
                <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_with_delimiter(trip.distance_miles) %> mi</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
