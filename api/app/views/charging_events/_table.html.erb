<% if events.any? %>
<div class="glass-panel rounded-2xl shadow-sm overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-slate-100">
    <h2 class="text-lg font-bold text-slate-900">Recent Charging</h2>
  </div>
  <table class="min-w-full">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Date</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Type</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Station</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Energy</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Rate</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Duration</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Cost</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% events.each do |event| %>
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="px-5 py-3 text-sm text-slate-600"><%= event.charged_at.strftime("%b %-d, %H:%M") %></td>
          <td class="px-5 py-3 text-sm">
            <span class="inline-block px-2 py-1 rounded-md text-xs font-medium border <%= event.location_type == 'depot' ? 'bg-teal-50 text-teal-700 border-teal-100' : 'bg-slate-100 text-slate-700 border-slate-200' %>">
              <%= event.location_type.titleize %>
            </span>
          </td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= event.station_name %></td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= event.energy_added_kwh %> kWh</td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= event.charge_rate_kw %> kW</td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= event.duration_minutes %> min</td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_to_currency(event.cost) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
