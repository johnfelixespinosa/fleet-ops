<% if records.any? %>
<div class="glass-panel rounded-2xl shadow-sm overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-slate-100">
    <h2 class="text-lg font-bold text-slate-900"><%= title %></h2>
  </div>
  <table class="min-w-full">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Type</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Date</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Mileage</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Service Center</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Cost</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Duration</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% records.each do |record| %>
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="px-5 py-3 text-sm font-bold text-slate-900"><%= record.maintenance_type.titleize %></td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= record.completed_at.strftime("%b %-d, %Y") %></td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_with_delimiter(record.mileage_at_service) %> mi</td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= record.service_center.name %></td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_to_currency(record.cost) %></td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_with_precision(record.duration_hours, precision: 1) %> hrs</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
