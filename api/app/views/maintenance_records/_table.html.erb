<% if records.any? %>
<div class="bg-white rounded-lg shadow overflow-hidden mb-6">
  <div class="px-5 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900"><%= title %></h2>
  </div>
  <table class="min-w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Mileage</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Service Center</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Cost</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Duration</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% records.each do |record| %>
        <tr class="even:bg-gray-50">
          <td class="px-5 py-3 text-sm font-medium text-gray-900"><%= record.maintenance_type.titleize %></td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= record.completed_at.strftime("%b %-d, %Y") %></td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= number_with_delimiter(record.mileage_at_service) %> mi</td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= record.service_center.name %></td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= number_to_currency(record.cost) %></td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= number_with_precision(record.duration_hours, precision: 1) %> hrs</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
