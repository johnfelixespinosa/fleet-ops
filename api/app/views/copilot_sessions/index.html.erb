<% content_for(:title) { "FleetOps — Copilot Sessions" } %>
<% content_for(:page_heading) { "Copilot Sessions" } %>
<% content_for(:page_subheading) { "#{@total_count} session#{"s" if @total_count != 1} · #{@total_tools} total tool call#{"s" if @total_tools != 1}" } %>

<% if @sessions.any? %>
  <div class="space-y-3">
    <% @sessions.each do |session| %>
      <%= link_to copilot_session_path(session), class: "block glass-panel rounded-2xl p-5 shadow-sm hover:border-slate-300 transition-all group" do %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-teal-50 border border-teal-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            </div>
            <div>
              <p class="font-bold text-slate-900 text-sm"><%= session.user_name %></p>
              <p class="text-xs text-slate-500 mt-0.5"><%= session.session_summary || "No summary" %></p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-right hidden sm:block">
              <p class="text-xs text-slate-500"><%= session.created_at.strftime("%b %-d, %Y at %I:%M %p") %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= session.tool_count %> tool call<%= "s" if session.tool_count != 1 %></p>
            </div>
            <% badge_color = case session.outcome
              when "completed" then "bg-teal-50 text-teal-700 border-teal-100"
              when "in_progress" then "bg-amber-50 text-amber-700 border-amber-100"
              when "successful_recommendation" then "bg-teal-50 text-teal-700 border-teal-100"
              else "bg-slate-100 text-slate-600 border-slate-200"
              end %>
            <span class="px-2.5 py-1 rounded-md text-xs font-bold border <%= badge_color %>">
              <%= session.outcome&.titleize || "Unknown" %>
            </span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-slate-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="glass-panel rounded-2xl p-12 shadow-sm text-center">
    <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <p class="text-slate-500 font-medium">No copilot sessions yet</p>
    <p class="text-slate-400 text-sm mt-1">Start a session in the FleetOps Copilot CLI to see activity here</p>
  </div>
<% end %>
