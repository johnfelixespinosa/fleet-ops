<% if pagination[:total_pages] > 1 %>
  <div class="flex items-center justify-between mt-4 px-1">
    <span class="text-xs text-slate-400">
      Showing <%= (pagination[:page] - 1) * pagination[:per_page] + 1 %>–<%= [pagination[:page] * pagination[:per_page], pagination[:total]].min %> of <%= pagination[:total] %>
    </span>
    <div class="flex gap-1">
      <% (1..pagination[:total_pages]).each do |p| %>
        <%= link_to p, url_for(request.query_parameters.merge(pagination[:param_name] => p)), class: "w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold transition-colors #{p == pagination[:page] ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
      <% end %>
    </div>
  </div>
<% end %>
