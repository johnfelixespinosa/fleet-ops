<% content_for(:title) { "FleetOps — Vehicles" } %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Fleet Vehicles</h1>
  <p class="text-sm text-gray-500 mt-1"><%= @vehicles.count %> vehicles</p>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Unit</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Make / Model</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Year</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Mileage</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Battery</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Next Service</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Miles Left</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @vehicles.each do |vehicle| %>
        <tr class="even:bg-gray-50 hover:bg-blue-50">
          <td class="px-5 py-3 text-sm font-medium">
            <div class="flex items-center gap-2">
              <%= vehicle_icon(vehicle.make, size: 32) %>
              <%= link_to vehicle.unit_number, vehicle_path(vehicle), class: "text-blue-600 hover:underline" %>
            </div>
          </td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= vehicle.make %> <%= vehicle.model %></td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= vehicle.year %></td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= number_with_delimiter(vehicle.current_mileage) %></td>
          <td class="px-5 py-3 text-sm text-right <%= vehicle.battery_health_percent < 95 ? 'text-amber-600 font-medium' : 'text-gray-700' %>">
            <%= vehicle.battery_health_percent %>%
          </td>
          <td class="px-5 py-3 text-sm"><%= vehicle_status_badge(vehicle.status) %></td>
          <td class="px-5 py-3 text-sm text-gray-700"><%= vehicle.next_maintenance_type.titleize %></td>
          <td class="px-5 py-3 text-sm text-right <%= vehicle.miles_to_maintenance < 5000 ? 'text-red-600 font-medium' : 'text-gray-700' %>">
            <%= number_with_delimiter(vehicle.miles_to_maintenance) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
