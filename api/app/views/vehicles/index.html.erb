<% content_for(:title) { "FleetOps — Vehicles" } %>
<% content_for(:page_heading) { "Fleet Vehicles" } %>
<% content_for(:page_subheading) { "#{@vehicles.count} vehicles" } %>

<div class="glass-panel rounded-2xl shadow-sm overflow-hidden">
  <table class="min-w-full">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Unit</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Make / Model</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Year</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Mileage</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Battery</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Status</th>
        <th class="px-5 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider">Next Service</th>
        <th class="px-5 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Miles Left</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @vehicles.each do |vehicle| %>
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="px-5 py-3 text-sm font-medium">
            <div class="flex items-center gap-2">
              <%= vehicle_icon(vehicle.make, size: 32) %>
              <%= link_to vehicle.unit_number, vehicle_path(vehicle), class: "text-teal-600 hover:text-teal-700 font-medium" %>
            </div>
          </td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= vehicle.make %> <%= vehicle.model %></td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= vehicle.year %></td>
          <td class="px-5 py-3 text-sm text-right text-slate-600"><%= number_with_delimiter(vehicle.current_mileage) %></td>
          <td class="px-5 py-3 text-sm text-right <%= vehicle.battery_health_percent < 95 ? 'text-amber-600 font-medium' : 'text-slate-600' %>">
            <%= vehicle.battery_health_percent %>%
          </td>
          <td class="px-5 py-3 text-sm"><%= vehicle_status_badge(vehicle.status) %></td>
          <td class="px-5 py-3 text-sm text-slate-600"><%= vehicle.next_maintenance_type.titleize %></td>
          <td class="px-5 py-3 text-sm text-right <%= vehicle.miles_to_maintenance < 5000 ? 'text-red-600 font-medium' : 'text-slate-600' %>">
            <%= number_with_delimiter(vehicle.miles_to_maintenance) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
