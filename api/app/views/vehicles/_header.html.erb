<div class="glass-panel rounded-2xl shadow-sm p-6 mb-6">
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-4">
      <%= vehicle_icon(vehicle.make, size: 56) %>
      <div>
        <h1 class="text-2xl font-bold text-slate-900"><%= vehicle.unit_number %></h1>
        <p class="text-slate-500 mt-1"><%= vehicle.make %> <%= vehicle.model %> (<%= vehicle.year %>)</p>
      </div>
    </div>
    <div><%= vehicle_status_badge(vehicle.status) %></div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-6">
    <div>
      <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Mileage</p>
      <p class="text-lg font-semibold text-slate-900 mt-1"><%= number_with_delimiter(vehicle.current_mileage) %> mi</p>
    </div>
    <div>
      <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Battery Health</p>
      <p class="text-lg font-semibold mt-1 <%= vehicle.battery_health_percent < 95 ? 'text-amber-600' : 'text-teal-600' %>">
        <%= vehicle.battery_health_percent %>%
      </p>
    </div>
    <div>
      <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Next Service</p>
      <p class="text-sm font-medium text-slate-900 mt-1"><%= vehicle.next_maintenance_type.titleize %></p>
      <p class="text-xs <%= vehicle.miles_to_maintenance < 5000 ? 'text-red-600 font-medium' : 'text-slate-500' %>">
        <%= number_with_delimiter(vehicle.miles_to_maintenance) %> mi remaining
      </p>
    </div>
    <div>
      <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Range / Capacity</p>
      <p class="text-sm text-slate-900 mt-1"><%= vehicle.range_miles %> mi / <%= vehicle.battery_capacity_kwh %> kWh</p>
    </div>
  </div>

  <% if vehicle.annual_inspection_due.present? %>
    <div class="mt-4 pt-4 border-t border-slate-100 flex items-center gap-6 text-sm text-slate-500">
      <span>Annual Inspection Due: <strong class="<%= vehicle.annual_inspection_due < 14.days.from_now ? 'text-red-600' : 'text-slate-900' %>"><%= vehicle.annual_inspection_due.strftime("%b %-d, %Y") %></strong></span>
      <% if vehicle.last_maintenance_date %>
        <span>Last Service: <strong class="text-slate-900"><%= vehicle.last_maintenance_date.strftime("%b %-d, %Y") %></strong></span>
      <% end %>
    </div>
  <% end %>
</div>
