#!/bin/bash
# Launch FleetOps Copilot with isolated skills (hides global ~/.claude/skills)
GLOBAL_SKILLS="$HOME/.claude/skills"
GLOBAL_PLUGINS="$HOME/.claude/plugins"
HIDDEN_SKILLS="$HOME/.claude/_skills_hidden"
HIDDEN_PLUGINS="$HOME/.claude/_plugins_hidden"

# Hide global skills/plugins
[ -d "$GLOBAL_SKILLS" ] && mv "$GLOBAL_SKILLS" "$HIDDEN_SKILLS"
[ -d "$GLOBAL_PLUGINS" ] && mv "$GLOBAL_PLUGINS" "$HIDDEN_PLUGINS"

# Restore on exit (even if claude crashes)
restore() {
  [ -d "$HIDDEN_SKILLS" ] && mv "$HIDDEN_SKILLS" "$GLOBAL_SKILLS"
  [ -d "$HIDDEN_PLUGINS" ] && mv "$HIDDEN_PLUGINS" "$GLOBAL_PLUGINS"
}
trap restore EXIT

cd "$(dirname "$0")"

WELCOME="On your VERY FIRST response in this session, before answering the user's question, always start with this welcome block (formatted as a table):

Welcome to FleetOps Copilot — your AI fleet operations assistant.

Available commands:
/maintenance  — Scan the fleet for vehicles approaching service thresholds
/health       — Run a health check on a specific vehicle
/recommend    — Draft a formal maintenance recommendation
/service-brief — Generate a service brief to send to a mechanic shop

Or just ask anything about the fleet in plain English.

Then answer whatever the user asked."

claude --mcp-config mcp.json --strict-mcp-config --append-system-prompt "$WELCOME" "$@"
