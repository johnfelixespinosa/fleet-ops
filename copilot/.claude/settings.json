{
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "bin/hooks/session-start.sh"
      }]
    }],
    "PreToolUse": [
      {
        "matcher": "mcp__fleetops__vehicles_due_for_maintenance|mcp__fleetops__upcoming_trips_for_vehicle|mcp__fleetops__service_centers_near_route|mcp__fleetops__vehicle_health_summary|mcp__fleetops__draft_maintenance_recommendation|mcp__fleetops__fleet_query",
        "hooks": [{
          "type": "command",
          "command": "if [ ! -f /tmp/fleetops-audit/.safety-gate-marker ]; then echo 'BLOCKED: Fleet safety protocols must be loaded first.' && exit 1; fi"
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__fleetops__vehicles_due_for_maintenance|mcp__fleetops__upcoming_trips_for_vehicle|mcp__fleetops__service_centers_near_route|mcp__fleetops__vehicle_health_summary|mcp__fleetops__draft_maintenance_recommendation|mcp__fleetops__fleet_query",
        "hooks": [{
          "type": "command",
          "command": "bin/hooks/post-tool-use.sh"
        }]
      }
    ],
    "UserPromptSubmit": [{
      "hooks": [{
        "type": "command",
        "command": "echo 'ROUTING: Classify this request as exactly one of: [find-maintenance-opportunities, vehicle-health-check, draft-maintenance-plan, mechanic-service-brief, general-question]. Activate the matching skill and generate the corresponding HTML report. If general-question, answer directly using MCP tools with evidence.'"
      }]
    }],
    "Stop": [{
      "hooks": [{
        "type": "command",
        "command": "bin/hooks/stop.sh"
      }]
    }]
  }
}
